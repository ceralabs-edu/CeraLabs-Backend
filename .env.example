# ===== Database =====
DB_URL=jdbc:postgresql://localhost:5432/your_database
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ===== MinIO =====
MINIO_HOST=your_minio_host
MINIO_PORT=9010
MINIO_ACCESS=your_minio_access_key
MINIO_SECRET=your_minio_secret_key
MINIO_BUCKET_PFP=your_bucket_name

# ===== LLM =====
LLM_PROVIDER=GEMINI
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gemini-2.5-flash
LLM_VALIDATE_ENDPOINT=http://your_host:port/api/v1/validate-key
LLM_QA_ENDPOINT=http://your_host:port/workflow
LLM_TOP_K=5

# ===== JWT =====
JWT_SECRET_KEY=your_jwt_secret_key
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ===== JPA (optional override) =====
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=true
